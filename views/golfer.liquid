{% render 'partials/head.liquid' %}
{% render 'partials/nav.liquid' %}

<main class="container">

  <!-- Profiel header -->
  {% comment %} Divjes weghalen Ul Li {% endcomment %}
  <section class="profiel-header">

    <div class="profiel-hello">
        <img src="https://fdnd-agency.directus.app/assets/{{ golfer.photo }}?width=128&height=128&fit=cover&format=webp" 
          alt="{{ golfer.name }}"
          loading="eager">
        
      <div>
        <p class="welkom-tekst">Welkom terug,</p>
        <h1>{{ golfer.name }}</h1>
      </div>
    </div>    

    <div class="hcp-stats">

      <div class="stat">
        <p class="stat-label">HCP</p>
        <p class="stat-waarde">{{ golfer.handicap | round: 1 }}</p>
      </div>

      <div class="stat">
        <p class="stat-label">Vorige</p>
        <p class="stat-waarde">{{ golfer.previous_handicap | round: 1 }}</p>
      </div>

      <div class="stat">
        <p class="stat-label">Verbetering</p>
        <p class="stat-waarde">{{ golfer.improvement | round: 1 }}</p>
      </div>

      <div class="stat">
        <p class="stat-label">Low</p>
        <p class="stat-waarde">{{ golfer.low | round: 1 }}</p>
      </div>

      <div class="stat">
        <p class="stat-label">Doel</p>
        <p class="stat-waarde">{{ golfer.goal_target | round: 1 }}</p>
      </div>
      
    </div>
  </section>

  <!-- Recente rondes -->
  {% comment %} data expliciet meegeven in partial aanroeping {% endcomment %}
{% render 'partials/recente-rondes.liquid', rondes: rondes, golfer: golfer, status: status %}

  <!-- Doelen -->

{% render 'partials/doel.liquid', golfer: golfer %}

  <section class="doelen">
    <h2>Doelen</h2>
    <ul>
      {% for milestone in milestones %}
      <li class="doel-item {% if milestone.completed %}doel-compleet{% endif %}">
        <div class="doel-info">
          <p>{{ milestone.title }}</p>
          <p class="doel-voortgang">{{ milestone.current }} / {{ milestone.target }}</p>
        </div>
        <div class="doel-balk-wrapper">
          <div class="doel-balk" style="width: {{ milestone.current | times: 100 | divided_by: milestone.target }}%"></div>
        </div>
      </li>
      {% endfor %}
    </ul>
  </section>

  <!-- Ranking -->
  <section class="ranking">
    <h2>Ranking</h2>
    {% for item in ranking %}
    <div class="ranking-categorie">
      <h3>{{ item.category }}</h3>
      <ul>
        {% for rank in item.rankings %}
        <li>{{ rank.rank }}. {{ rank.name }} - {{ rank.value }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endfor %}
  </section>

</main>

{% render 'partials/foot.liquid' %}